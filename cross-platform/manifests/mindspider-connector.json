{
  "name": "mindspider-connector",
  "version": "1.0.0",
  "description": "Live social listening feed connector. Pulls trending topics from social platforms with sentiment analysis.",
  "author": "TECHKNOWMAD LABS",
  "license": "MIT",
  "repository": "https://github.com/TECHKNOWMAD-LABS/cortex-research-suite/tree/main/skills/mindspider-connector",
  "capabilities": [
    {
      "name": "fetch_topics",
      "description": "Pull trending topics from social platforms with sentiment analysis",
      "input_schema": {
        "type": "object",
        "properties": {
          "source": {
            "type": "string",
            "enum": [
              "demo",
              "scrapling"
            ],
            "default": "demo",
            "description": "Data source to use"
          },
          "platforms": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of social platforms to monitor"
          }
        },
        "required": []
      }
    }
  ],
  "platforms": {
    "claude_skill": {
      "entry_point": "SKILL.md"
    },
    "mcp_server": {
      "transport": "stdio",
      "entry_point": "mcp/mindspider-connector/server.py",
      "command": "uv",
      "args": [
        "--directory",
        "mcp/mindspider-connector",
        "run",
        "python",
        "server.py"
      ]
    },
    "langchain": {
      "tool_class": "Fetch_topicsTool",
      "module_path": "langchain.mindspider_connector.tools"
    },
    "crewai": {
      "tool_class": "Fetch_topicsTool",
      "module_path": "crewai.mindspider_connector.tools"
    },
    "openai_gpt": {
      "action_schema_url": "https://api.techknowmad.ai/skills/mindspider-connector/openapi.json",
      "openapi_spec": "openai/mindspider-connector/openapi.json"
    },
    "github_copilot": {
      "mcp_config": {
        "command": "uv",
        "args": [
          "--directory",
          "mcp/mindspider-connector",
          "run",
          "python",
          "server.py"
        ]
      }
    }
  },
  "dependencies": {
    "python": ">=3.12",
    "packages": []
  }
}

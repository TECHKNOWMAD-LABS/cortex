{\n  "name": "context-engineer",\n  "version": "1.0.0",\n  "description": "Builds optimal context windows for LLM interactions. Compresses, prioritizes, and structures information to maximize relevance within token limits. Implements retrieval-augmented context assembly.",\n  "author": "TECHKNOWMAD LABS",\n  "license": "MIT",\n  "repository": "https://github.com/TECHKNOWMAD-LABS/cortex-research-suite/tree/main/skills/context-engineer",\n  "capabilities": [\n    {\n      "name": "build_context",\n      "description": "Assemble an optimal context window from multiple sources within token limits",\n      "input_schema": {\n        "type": "object",\n        "properties": {\n          "sources": {\n            "type": "array",\n            "items": {\n              "type": "string"\n            },\n            "description": "Paths or URIs to context sources"\n          },\n          "query": {\n            "type": "string",\n            "description": "Query to optimize context for"\n          },\n          "max_tokens": {\n            "type": "integer",\n            "default": 8000,\n            "description": "Maximum token budget"\n          },\n          "strategy": {\n            "type": "string",\n            "enum": [\n              "relevance",\n              "recency",\n              "hybrid"\n            ],\n            "default": "hybrid"\n          }\n        },\n        "required": [\n          "sources",\n          "query"\n        ]\n      },\n      "output_schema": {\n        "type": "object",\n        "properties": {\n          "context": {\n            "type": "string"\n          },\n          "token_count": {\n            "type": "integer"\n          },\n          "sources_used": {\n            "type": "array",\n            "items": {\n              "type": "string"\n            }\n          },\n          "compression_ratio": {\n            "type": "number"\n          }\n        }\n      }\n    }\n  ],\n  "platforms": {\n    "claude_skill": {\n      "entry_point": "SKILL.md",\n      "triggers": [\n        "builds",\n        "optimal",\n        "context",\n        "windows",\n        "interactions",\n        "compresses",\n        "prioritizes",\n        "structures",\n        "information",\n        "maximize",\n        "relevance",\n        "within",\n        "token",\n        "limits",\n        "implements"\n      ]\n    },\n    "mcp_server": {\n      "transport": "stdio",\n      "entry_point": "mcp/context-engineer/server.py",\n      "command": "uv",\n      "args": [\n        "--directory",\n        "mcp/context-engineer",\n        "run",\n        "python",\n        "server.py"\n      ]\n    },\n    "langchain": {\n      "tool_class": "ContextEngineerTool",\n      "module_path": "langchain.context_engineer.tools"\n    },\n    "crewai": {\n      "tool_class": "ContextEngineerTool",\n      "module_path": "crewai.context_engineer.tools"\n    },\n    "openai_gpt": {\n      "action_schema_url": "https://api.techknowmad.ai/skills/context-engineer/openapi.json",\n      "openapi_spec": "openai/context-engineer/openapi.json"\n    },\n    "github_copilot": {\n      "mcp_config": {\n        "command": "uv",\n        "args": [\n          "--directory",\n          "mcp/context-engineer",\n          "run",\n          "python",\n          "server.py"\n        ]\n      }\n    }\n  },\n  "dependencies": {\n    "python": ">=3.12",\n    "packages": [],\n    "system": []\n  }\n}
{\n  "name": "persistent-memory",\n  "version": "1.0.0",\n  "description": "Persistent key-value memory system for AI agents. Stores, retrieves, and manages structured knowledge across sessions with TTL, tagging, and semantic search support.",\n  "author": "TECHKNOWMAD LABS",\n  "license": "MIT",\n  "repository": "https://github.com/TECHKNOWMAD-LABS/cortex-research-suite/tree/main/skills/persistent-memory",\n  "capabilities": [\n    {\n      "name": "memory_operation",\n      "description": "Store, retrieve, search, or manage persistent memory entries",\n      "input_schema": {\n        "type": "object",\n        "properties": {\n          "action": {\n            "type": "string",\n            "enum": [\n              "store",\n              "retrieve",\n              "search",\n              "delete",\n              "list"\n            ],\n            "description": "Memory operation"\n          },\n          "key": {\n            "type": "string",\n            "description": "Memory key"\n          },\n          "value": {\n            "type": "object",\n            "description": "Value to store"\n          },\n          "query": {\n            "type": "string",\n            "description": "Search query"\n          },\n          "tags": {\n            "type": "array",\n            "items": {\n              "type": "string"\n            },\n            "description": "Tags for filtering"\n          },\n          "ttl": {\n            "type": "integer",\n            "description": "Time-to-live in seconds"\n          }\n        },\n        "required": [\n          "action"\n        ]\n      },\n      "output_schema": {\n        "type": "object",\n        "properties": {\n          "status": {\n            "type": "string"\n          },\n          "data": {\n            "type": "object"\n          },\n          "results": {\n            "type": "array",\n            "items": {\n              "type": "object"\n            }\n          }\n        }\n      }\n    }\n  ],\n  "platforms": {\n    "claude_skill": {\n      "entry_point": "SKILL.md",\n      "triggers": [\n        "persistent",\n        "key-value",\n        "memory",\n        "system",\n        "agents",\n        "stores",\n        "retrieves",\n        "manages",\n        "knowledge",\n        "sessions",\n        "tagging",\n        "semantic",\n        "search",\n        "support"\n      ]\n    },\n    "mcp_server": {\n      "transport": "stdio",\n      "entry_point": "mcp/persistent-memory/server.py",\n      "command": "uv",\n      "args": [\n        "--directory",\n        "mcp/persistent-memory",\n        "run",\n        "python",\n        "server.py"\n      ]\n    },\n    "langchain": {\n      "tool_class": "PersistentMemoryTool",\n      "module_path": "langchain.persistent_memory.tools"\n    },\n    "crewai": {\n      "tool_class": "PersistentMemoryTool",\n      "module_path": "crewai.persistent_memory.tools"\n    },\n    "openai_gpt": {\n      "action_schema_url": "https://api.techknowmad.ai/skills/persistent-memory/openapi.json",\n      "openapi_spec": "openai/persistent-memory/openapi.json"\n    },\n    "github_copilot": {\n      "mcp_config": {\n        "command": "uv",\n        "args": [\n          "--directory",\n          "mcp/persistent-memory",\n          "run",\n          "python",\n          "server.py"\n        ]\n      }\n    }\n  },\n  "dependencies": {\n    "python": ">=3.12",\n    "packages": [],\n    "system": []\n  }\n}
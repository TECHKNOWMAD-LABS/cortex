{
  "name": "code-review-engine",
  "version": "1.0.0",
  "description": "Automated code review with multi-dimensional analysis: correctness, security, performance, maintainability, and style. Produces structured findings with severity, location, and suggested fixes.",
  "author": "TECHKNOWMAD LABS",
  "license": "MIT",
  "repository": "https://github.com/TECHKNOWMAD-LABS/cortex/tree/main/skills/code-review-engine",
  "capabilities": [
    {
      "name": "review_code",
      "description": "Run automated code review on a file or directory with multi-dimensional analysis",
      "input_schema": {
        "type": "object",
        "properties": {
          "target": {
            "type": "string",
            "description": "File or directory path to review"
          },
          "language": {
            "type": "string",
            "description": "Programming language (auto-detected if omitted)"
          },
          "dimensions": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "correctness",
                "security",
                "performance",
                "maintainability",
                "style"
              ]
            },
            "description": "Review dimensions to check"
          },
          "severity_threshold": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ],
            "default": "low"
          }
        },
        "required": [
          "target"
        ]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "warn",
              "fail"
            ]
          },
          "findings": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "summary": {
            "type": "object"
          },
          "score": {
            "type": "number"
          }
        }
      }
    }
  ],
  "platforms": {
    "claude_skill": {
      "entry_point": "SKILL.md",
      "triggers": [
        "code",
        "review",
        "multi-dimensional",
        "analysis",
        "correctness",
        "security",
        "performance",
        "maintainability",
        "style",
        "findings",
        "severity",
        "location",
        "suggested",
        "fixes"
      ]
    },
    "mcp_server": {
      "transport": "stdio",
      "entry_point": "mcp/code-review-engine/server.py",
      "command": "uv",
      "args": [
        "--directory",
        "mcp/code-review-engine",
        "run",
        "python",
        "server.py"
      ]
    },
    "langchain": {
      "tool_class": "CodeReviewEngineTool",
      "module_path": "langchain.code_review_engine.tools"
    },
    "crewai": {
      "tool_class": "CodeReviewEngineTool",
      "module_path": "crewai.code_review_engine.tools"
    },
    "openai_gpt": {
      "action_schema_url": "https://api.techknowmad.ai/skills/code-review-engine/openapi.json",
      "openapi_spec": "openai/code-review-engine/openapi.json"
    },
    "github_copilot": {
      "mcp_config": {
        "command": "uv",
        "args": [
          "--directory",
          "mcp/code-review-engine",
          "run",
          "python",
          "server.py"
        ]
      }
    }
  },
  "dependencies": {
    "python": ">=3.12",
    "packages": [],
    "system": []
  }
}
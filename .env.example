# Cortex Research Suite — Environment Configuration
# Copy to .env and fill in values as needed.
# All variables are optional — the suite works fully offline without them.

# === LLM Provider (optional — needed for eval_judge.py and live LLM calls) ===
# ANTHROPIC_API_KEY=sk-ant-...

# === MindSpider MySQL (optional — for --source mysql mode) ===
# MINDSPIDER_DB_URL=mysql://user:pass@host:3306/mindspider

# === Evolution Notifications (optional — Telegram bot for evolution updates) ===
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# === Evolution Notifications (optional — Discord webhook) ===
# DISCORD_WEBHOOK_URL=

# === Live Dashboard Server (optional) ===
# CORTEX_DASHBOARD_PORT=3117
